            "text": "\r\n\r\n\r\n\r\n<!DOCTYPE html PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\r\n<head>\r\n<script src=\"js/layout/studentLayoutNew.js\" type=\"text/javascript\"></script>\r\n</head>\r\n<html>\r\n\r\n<head>\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n\r\n<title>Knowledge Pro</title>\r\n<link rel=\"stylesheet\" href=\"js/newDesignPlugin/css/bootstrap.min.css\" type=\"text/css\" />\r\n<link rel=\"stylesheet\" href=\"js/newDesignPlugin/css/base.css\" type=\"text/css\" />\r\n<link rel=\"stylesheet\" href=\"js/newDesignPlugin/css/menustyle1.css\" type=\"text/css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/styles.css\"/>\r\n\r\n<script type=\"text/javascript\" src=\"js/newDesignPlugin/js/jquery-1.10.1.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/newDesignPlugin/js/bootstrap.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/newDesignPlugin/js/script.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/ajax/Ajax.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/ajax/AjaxUtil.js\"></script>\r\n<style type=\"text/css\">\r\n.cotbox {\r\n\twidth: 100%;\r\n\tfloat: left;\r\n\t margin-top: 130px; \r\n\t  overflow: auto;\r\n}\r\n</style>\r\n</head>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<!DOCTYPE html PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\r\n<html>\r\n<head>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"jquery.confirm/jquery.confirm/jquery.confirm.css\" />\r\n<script type=\"text/javascript\" src=\"jquery.confirm/jquery.confirm/jquery.confirm.js\"></script>\r\n<style type=\"text/css\">\r\n  .home {\r\n  cursor:pointer;\r\n  color: #183883; \r\n  font-size: 18px; \r\n  margin: 0; \r\n  padding: 0 30px;\r\n  }\r\n  .home:hover {\r\n  cursor:pointer;\r\n  font-size: 18px; \r\n  margin: 0; \r\n  padding: 0 30px;\r\n  color: #f55e15;\r\n  }\r\n  .header {\r\n\tbackground: #fff;\r\n\twidth: 100%;\r\n\theight: 130px;\r\n\ttop: 0;\r\n\tleft: 0;\r\n\tborder-bottom: 3px solid #001b3a;\r\n\tz-index: 100;\r\n\tposition: fixed;\r\n}\r\nul.nav ul {\r\n\tbox-shadow: 0 0 3px #333;\r\n    display: none;\r\n    height: auto;\r\n    margin: 0;\r\n    min-width: 190px;\r\n    padding: 0;\r\n    position: absolute;\r\n    z-index: 9999;\r\n}\r\n</style>\r\n</head>\r\n<body >\r\n<div class=\"fixed1\">\r\n<div class=\"header\"  >\r\n<div class=\"container\">\r\n<div class=\"row\" >\r\n\t<div class=\"col-xs-3 logo\">\r\n\t<a href=\"StudentLoginNewAction.do?method=returnHomePage\" >\r\n\t\r\n\t<img src='images/LoginImages/Logo.jpg' alt=\"Logo not available\" class=\"img-responsive\" />\r\n\t</div>\r\n\t<div class=\"col-md-5\" >\r\n\t</div>\r\n\t<div class=\"col-md-3\" style=\"font-size: 14px;font-weight: bold;\" align=\"right\">\r\n\t\r\n\t\tWelcome&nbsp;: &nbsp;<strong>2140134 </strong>\r\n\t &nbsp;&nbsp;\r\n\t\r\n\t\t\r\n\t\t\r\n\t\t\t<a class=\"btn-link\" style=\"font-size: 14px;font-weight: bold;\" href=\"StudentLoginAction.do?method=studentLogoutAction\">Sign out</a>\r\n\t\t\r\n\t\r\n\t</div>\r\n\r\n\r\n<div class=\"col-xs-9\">\r\n            \t<div class=\"topfull2\"><div class=\"menubox\">\r\n<a class=\"toggleMenu\" href=\"#\"><img src=\"images/icon-nav.jpg\" /></a>\r\n<ul class=\"nav NormalMenu\" >\r\n<li onclick=\"Home()\" class=\"home\" style=\"\">Home</li>\r\n\t\r\n\t\t\r\n\t\t\r\n\t\t<li class=\"test\" id=\"att\">\t<a href=\"#\" >Attendance </a>\r\n       <ul  style=\"left:-10%\">\r\n\t\t<li >\r\n\t\t\t\r\n\t\t\t\t\r\n\t\t\t\t\r\n\t\t\t\t\t<a  id=\"attendanceNonCJC\" \r\n\t\t\t\t\t\thref=\"javascript:void(0);\">\r\n\t\t\t\t\t\tAttendance </a>\r\n\t\t\t\t\t\r\n\t\t\t\t\r\n\t\t\t\r\n\t\t</li>\r\n\t\t<li></li>\r\n\t\t\r\n\t\t<li>\r\n\t\t\r\n\t\t</li>\r\n\t\t\r\n\t\t<li>\r\n\t\t\t<!-- <a\r\n\t\t\t\thref=\"studentWiseAttendanceSummary.do?method=getStudentAbscentWithCocularLeave\">Absence Details </a> -->\r\n\t\t\t<a  id=\"absenceDetailsId\"\r\n\t\t\t\thref=\"javascript:void(0);\">Absence Details </a>\t\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\t\r\n\t\t\t\t\r\n\t\t\t\t\r\n\t\t\t\t\t<a\r\n\t\t\t\t\t\thref=\"studentWiseAttendanceSummary.do?method=initPreviousStudentAttendanceSummeryChrist\">Previous Class Attendance</a>\r\n\t\t\t\t\r\n\t\t\t\r\n\t\t</li>\r\n\t\t<li></li>\r\n\t\t<li>\r\n\t\t\t<a href=\"viewMyTimeTable1.do?method=initViewStudentTimeTable\">View My Time Table</a>\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\r\n\t    <a href=\"StudentLoginNewAction.do?method=getOpenElectiveAttendanceDetails\">Open Elective Attendance</a>\r\n\t\t\r\n\t\t</li>\r\n\t\t\r\n\t\t<li>\r\n\t    \t<a href=\"StudentLoginNewAction.do?method=getLibraryAttendanceSummary\">Library Attendance&nbsp;\r\n\t    \t<img src=\"images/supportRequestnew_icon1.png\" width=\"25\" id=\"displayDownloadNew\" style=\"display:none;\"\theight=\"15\" class=\"blinkImage\"></img>\r\n\t\t\t</a>\r\n\t\t</li>\r\n\t\t\r\n\t</ul>\r\n\t</li>\r\n\t\t\r\n\t\t\r\n\r\n        \r\n\t\r\n\t<li class=\"test\"><a href=\"#\" >Downloads&nbsp;<img src=\"images/supportRequestnew_icon1.png\" width=\"25\" id=\"displayDownloadNew\"\r\n\t\t\t\tstyle=\"display:none;\"\theight=\"15\" class=\"blinkImage\"></img> </a>\r\n\t<ul style=\"left:-10%\">\r\n\t\t\r\n\t\t\r\n\t\t<li><a\r\n\t\t\thref=\"studentWiseAttendanceSummary.do?method=getInternalMarkDetails\">\r\n\t\tCIA-Mid Sem Result</a></li>\r\n\t\t\r\n\t\t\r\n\t\t<li><a\r\n\t\t\thref=\"studentWiseAttendanceSummary.do?method=getPreviousSemesterInternalMarkDetails\">\r\n\t\tPrevious Class CIA-MID Sem Result</a></li>\r\n\t\t\r\n\t\t\r\n\t\t\r\n\t\t\r\n\t\t<li><a\r\n\t\t\thref=\"studentWiseAttendanceSummary.do?method=getStudentLastSemesterClass\">\r\n\t\t     End Semester Marks</a></li>\r\n\t\t\r\n\t\t<li>\r\n\t\t\t<a href=\"StudentLoginNewAction.do?method=initMarksCard\">My Marks Card</a>\r\n\t\t</li>\r\n\t\t\r\n\t\t\r\n\t\t<li>\r\n\t\t\r\n\t\t</li>\r\n\t\t<!-- for multiple ese components marks display by ram -->\r\n\t\t<li>\r\n\t\t\t<!-- <a href=\"StudentLoginNewAction.do?method=multipleEseComponentMarksDisplay\"></a> -->\r\n\t\t\t<a href=\"StudentLoginNewAction.do?method=getStudentLastSemesterClass\">ESE Component Marks</a>\r\n\t\t\t \r\n\r\n\t\t</li>\r\n\t\t<!-- end -->\r\n\t\t\r\n\t\t\r\n\t\t<!--Added by Ashwini N Kandgal  -->\r\n\t\t<li>\r\n\t\t\t\r\n\t\t</li>\r\n\t\t<!-- Code ended by Ashwini N Kandgal -->\r\n\t\t\r\n\t\t\r\n\t\t\t<li><a href=\"StudentLoginNewAction.do?method=FeePayementReceipts\"> Fee Payment Details</a></li>\r\n\t\t\r\n\t\t\r\n\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t<li></li>\r\n\t\t\t\r\n\t\t\t<li></li>\r\n\t\t\r\n\t\t<li>\r\n\t\t\t\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\t\r\n\t\t\t<a href=\"StudentLoginNewAction.do?method=certificateCourseStatus&studentId=1161618&courseId=88\">Open Elective Status </a>\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\t\r\n\t\t</li>\r\n\t\t\r\n\t\t<li>\r\n\t\t\t\r\n\t\t</li>\r\n\t\t<li>\r\n\t\t\r\n\t\t</li>\r\n\t\t<li><!--<a href=\"hostelStudentViewMessage.do?method=initHostelStudentViewMessage\" >Student View Message </a>\r\n         --></li>\r\n         \r\n\t\t\r\n\t\t<li><a href=\"displaySyllabusCoursePlan.do?method=initStudentSyllabusAndCoursePlan\" >Course Pack </a></li>\r\n\t\t\r\n\t\r\n\t\t\r\n\t\t\r\n\t\t\r\n\t\t\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\t\t<li><a href=\"StudentLoginNewAction.do?method=initDocumentSubmissionStatus\" >Document Submission Status&nbsp;<img src=\"images/supportRequestnew_icon1.png\"\r\n\t\t\t\t\t\t\t\twidth=\"25\" height=\"15\" class=\"blinkImage\"> </a></li>\r\n\t\t\t\t\t\r\n\t\t\t\t\t\r\n\t\t\t\r\n\t\t\t\t\t\r\n\t\t\t  \r\n\t\t\t\r\n\t\t \r\n\t\t\t<li>\r\n\t\t\t\t<a href=\"StudentLoginNewAction.do?method=getCourseCompletionStatus\">Programme Completion Status</a>\r\n\t\t\t</li>\r\n\t\t\r\n\t\t <li>\r\n\t\t  \r\n\t\t \r\n\t\r\n\t \t</li>\r\n\t</ul>\r\n\t\r\n\t<script type=\"text/javascript\">\r\n\t $( \"#displayDownloadNew\" ).removeAttr( \"style\" );\r\n\t</script>\r\n\t\r\n\t\r\n\t</li>\r\n\t\r\n\r\n\r\n\t<li class=\"test\"><a href=\"#\">Apply Online&nbsp;<img src=\"images/supportRequestnew_icon1.png\" width=\"25\" id=\"displayOnlineNewLogo\"\r\n\t\t\t\tstyle=\"display:none;\"\theight=\"15\" class=\"blinkImage\"></img></a>\r\n\t<ul style=\"left:-10%\">\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t<!-- certificateRequest1.do?method=initCertificateRequest -->\r\n\t\t\t<li><a href=\"javascript:void(0);\" onclick=\"certificateRequest()\"> Certificate Request</a></li>\r\n\t\t\t<li><a href=\"certificateRequest1.do?method=getCertificateStatus\">Certificate Status</a></li>\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\r\n\t\t\t\r\n\t\t\r\n\t\t\r\n\t\t\t\r\n\t\t\t\t\r\n\t\t\t\t\t<li> \r\n\t\t\t\t\t<!-- onlineExamSuppApplication.do?method=initConvocationRegistration -->\r\n\t\t\t\t\t<a href=\"javascript:void(0);\" onclick=\"convocationRegistration()\">Convocation Registration\r\n\t\t\t\t\t&nbsp; <img src=\"images/supportRequestnew_icon1.png\" width=\"25\" height=\"15\" class=\"blinkImage\">\r\n\t\t\t\t\t</a> </li>\r\n\t\t\t\t\t\r\n\t\t\t\t\r\n\t\t\t\r\n\t\t\t<!--attestMarksCard.do?method=initAttestMarksCard&studentId=1161618&isOriginalTranscript=false  -->\r\n\t\t\t<li> <a href=\"javascript:void(0);\" onclick=\"marksCardAttestation(1161618)\">Marks Card Attestation\r\n\t\t\t\t\t&nbsp; <img src=\"images/supportRequestnew_icon1.png\" width=\"25\" height=\"15\" class=\"blinkImage\">\r\n\t\t\t\t</a> \r\n\t\t\t</li>\r\n\t\t\t<!-- attestMarksCard.do?method=initOriginalTransScriptRequest&studentId=1161618&isOriginalTranscript=true -->\r\n\t\t\t<li> <a href=\"javascript:void(0);\" onclick=\"originalTranscriptRequest(1161618)\">Original Transcript Request \r\n\t\t\t\t\t&nbsp; <img src=\"images/supportRequestnew_icon1.png\" width=\"25\" height=\"15\" class=\"blinkImage\">\r\n\t\t\t\t</a> \r\n\t\t\t</li> \r\n\t\t</ul>\r\n\t</li>\r\n\t\r\n\t<script type=\"text/javascript\">\r\n\t $( \"#displayOnlineNewLogo\" ).removeAttr( \"style\" );\r\n\t</script>\r\n\t\r\n\t\r\n\t\t<li class=\"test\"><a href=\"#\">Student Support </a>\r\n\t\t<ul style=\"left:-10%\">\r\n\t\t\r\n\t\t\t<li><a href=\"studentSupportRequest1.do?method=initStudentSupportRequest\">Support Request </a></li>\r\n\t\t\t<li><a href=\"facultyLocation.do?method=initFacultyLocation\">Faculty Location </a></li>\r\n\t\t\t\r\n\t\t                  <li><a href=\"http://databank.christuniversity.in/\"  target=\"_blank\">Data Bank </a></li> \r\n\t\t                  <li><a href=\"http://courses.christuniversity.in/login/index.php\" target=\"_blank\">My Course</a></li>\r\n\t\t                  \r\n\t\t        \r\n\t\t\t\r\n\t\t\t\r\n\t\t</ul>\r\n<!-- \t\t\t\t<li onclick=\"facultyLocation()\" class=\"home\" style=\"\" >Faculty Location</a></li>\r\n -->    </ul>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</div>\r\n</body>\r\n<script src=\"jquery/development-bundle/jquery-1.7.1.js\"></script>\r\n<script type='text/javascript' src=\"js/auditorium/jquery-ui.min.js\"></script>\r\n<link rel='stylesheet'  href=\"css/auditorium/start/jquery-ui.css\" />\r\n<script language=\"JavaScript\" src=\"js/calendar_us.js\"></script>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"jquery.confirm/jquery.confirm/jquery.confirm.css\" />\r\n<script src=\"jquery.confirm/jquery.confirm/jquery.confirm.js\"></script>\r\n<script language=\"JavaScript\" src=\"js/layout/studentHeaderNew.js?version=2.11\"></script>\r\n</html>\r\n<div class=\"cotbox\">\r\n<div class=\"container cothight\" >\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<!-- <script src=\"jquery/js/jquery-1.9.0.js\" type=\"text/javascript\"></script> -->\r\n<!-- <script type='text/javascript' src=\"js/syllabus/jspdf.min.js\"></script> -->\r\n<script src=\"js/questionbank/jquery-1.11.1.min.js\"></script>\r\n<script src=\"js/questionbank/jquery.dataTables.min.js\"></script>\r\n<script src=\"js/questionbank/dataTables.bootstrap.js\"></script>\r\n<link rel=\"stylesheet\" type=\"text/css\"\r\n\thref=\"css/questionbank/bootstrap.min.css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\"\r\n\thref=\"css/questionbank/jquery.dataTables.css\" />\r\n<link type=\"text/css\"\r\n\thref=\"jquery/css/ui-lightness/jquery-ui-1.8.18.custom.css\"\r\n\trel=\"stylesheet\" />\r\n<script src=\"jquery/js/jquery-ui-1.10.0.custom.min.js\"\r\n\ttype=\"text/javascript\"></script>\r\n\r\n<style>\r\n#editor {\r\n\tbackground-color: white;\r\n\tfont-family: Arial;\r\n\tfont-size: 20px;\r\n}\r\n\r\n#loading-div-background {\r\n\tdisplay: none;\r\n\tposition: fixed;\r\n\twidth: 100%;\r\n\theight: 100%;\r\n\ttop: 0;\r\n\tleft: 0;\r\n}\r\n\r\n#loading-div {\r\n\twidth: 400px;\r\n\theight: 200px;\r\n\ttext-align: center;\r\n\t/* color: #202020; */\r\n\tposition: absolute;\r\n\tleft: 50%;\r\n\ttop: 50%;\r\n\tmargin-left: -150px;\r\n\tmargin-top: -100px;\r\n\tpadding-left: 100px;\r\n}\r\n\r\n#scrollbox {\r\n\toverflow: auto;\r\n\theight: 500px;\r\n\tpadding: 0, 5px;\r\n\tborder: 1px solid #b7b7b7;\r\n\tmax-width: 100%;\r\n}\r\n\r\n.comboLarge {\r\n\tfont-family: \"calibri\", Garamond, 'Comic Sans';\r\n\tfont-size: 14px;\r\n\ttext-decoration: none;\r\n\tfont-weight: normal;\r\n\twidth: 300px;\r\n\theight: 20px;\r\n\tcolor: #183883;\r\n}\r\n</style>\r\n<form name=\"facultylocationform\" method=\"post\" action=\"/KnowledgePro/facultyLocation.do\">\r\n\t<input type=\"hidden\" name=\"formName\" value=\"facultylocationform\">\r\n\t<input type=\"hidden\" name=\"pageType\" value=\"1\">\r\n\r\n\t<input type=\"hidden\" name=\"method\" value=\"searchDetails\" id=\"method\">\r\n\t<input type=\"hidden\" name=\"departmentId\" value=\"\" id=\"departmentId\">\r\n\t<input type=\"hidden\" name=\"deptNameList\" value=\"ADMINISTRATION (NCR),AI AND DATA SCIENCE ENGINEERING,BGR CAMPUS OFFICE,BUSINESS AND MANAGEMENT,BUSINESS AND MANAGEMENT  (BBA),BUSINESS AND MANAGEMENT  (Lavasa BBA),BUSINESS AND MANAGEMENT  (Lavasa MBA),BUSINESS AND MANAGEMENT 