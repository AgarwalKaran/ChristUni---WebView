            "mimeType": "application/javascript",
            "text": "\r\n$(function(){\r\n\r\n\t var deptNameArray = $('#deptNameList').val().split(\",\");\r\n\t var data = Array();\r\n\t for(var i = 0; i < deptNameArray.length ; i++){\r\n\t\t \tdata.push(deptNameArray[i].trim());\r\n\t\t }\r\n\t $('#deptName').autocomplete({\r\n\t\t   source: function(req, responseFn) { \r\n\t\t    var matches = new Array();\r\n\t          var needle = req.term.toLowerCase();\r\n\r\n\t          var len = data.length;\r\n\t          for(i = 0; i < len; ++i)\r\n\t          {\r\n\t              var haystack = data[i].toLowerCase();\r\n\t              if(haystack.indexOf(needle) == 0 ||\r\n\t                 haystack.indexOf(\" \" + needle) != -1)\r\n\t              {\r\n\t                  matches.push(data[i]);\r\n\t              }\r\n\t          }\r\n\t          responseFn( matches );\r\n\t\t    },\r\n\t    minLength: 1\r\n\t   });\r\n\t//Added by Ashwini N Kandgal\r\n\t var empty_count=0;\r\n\t var empNameArray = $('#employeeNameList').val().split(\",\");\r\n\t var data1 = Array();\r\n\t for(var i = 0; i < empNameArray.length ; i++){\r\n\t\t \tdata1.push(empNameArray[i].trim());\r\n\t\t }\r\n\t $('#employeeName').autocomplete({\r\n\t\t   source: function(req, responseFn) { \r\n\t\t    var matches = new Array();\r\n\t          var needle = req.term.toLowerCase();\r\n\r\n\t          var len = data1.length;\r\n\t          for(i = 0; i < len; ++i)\r\n\t          {\r\n\t              var haystack = data1[i].toLowerCase();\r\n\t              if(haystack.indexOf(needle) == 0 ||\r\n\t                 haystack.indexOf(\" \" + needle) != -1)\r\n\t              {\r\n\t                  matches.push(data1[i]);\r\n\t              }\r\n\t          }\r\n\t          responseFn( matches );\r\n\t\t    },\r\n\t    minLength: 1\r\n\t   });\r\n\r\n});\r\n\tfunction cancelAction() {\r\n\t\tdocument.location.href =\"StudentLoginNewAction.do?method=returnHomePage\";\r\n\t}\r\n\t"
