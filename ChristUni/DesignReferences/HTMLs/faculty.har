            "text": "var clickCount = 0;\r\nfunction getFeeDemandSlip(){\r\n\tvar url = \"feeDemandSlip1.do?method=getStudentFeeDemandSlipDetails\";\r\n\tmyRef = window .open(url, \"FeeDemandSlipReceipt\", \"left=20,top=20,width=900,height=600,toolbar=1,resizable=0,scrollbars=1\");\r\n}\r\n\r\nfunction getFeeDemandSlipForPhd(){\r\n\tvar url = \"feeDemandSlip1.do?method=getPhdStudentFeeDemandSlipDetails\";\r\n\tmyRef = window .open(url, \"feeDemandSlipReceiptForPhd\", \"left=20,top=20,width=900,height=600,toolbar=1,resizable=0,scrollbars=1\");\r\n}\r\n\r\n\r\nfunction Home(){\r\n\tdocument.location.href=\"StudentLoginNewAction.do?method=returnHomePage\";\r\n}\r\n\r\n$(document).ready(function(){\r\n\t$(\"#attendanceNonCJC\").click(function(e){\r\n\t   setTimeout('Decrement1()',1000);\r\n\t   document.location.href = \"studentWiseAttendanceSummary.do?method=getIndividualStudentWiseSubjectAndActivityAttendanceSummary\";\r\n\t});\r\n\t$(\"#attendanceCJC\").click(function(e){\r\n\t   setTimeout('Decrement1()',1000);\r\n\t   document.location.href = \"studentWiseAttendanceSummary.do?method=getIndividualStudentWiseAttendanceSummary\";\r\n\t});\r\n\t\t$(\"#valueAddedAttendance\").click(function(e){\r\n\t   setTimeout('Decrement1()',1000);\r\n\t   document.location.href = \"studentWiseAttendanceSummary.do?method=getIndividualStudentWiseValuAddedAttendanceSummary\";\r\n\t});\r\n\t\r\n\t\r\n\t$(\"#absenceDetailsId\").click(function(e){\r\n\t   setTimeout('Decrement1()',1000);\r\n\t   document.location.href = \"studentWiseAttendanceSummary.do?method=getStudentAbscentWithCocularLeave\";\r\n\t});\r\n\t$(\"#hallticketBlockId\").click(function(e){\r\n\t   setTimeout('Decrement1()',1000);\r\n\t   document.location.href = \"StudentLoginNewAction.do?method=studentLoginHallTicketBlock&supHallTicket=false\";\r\n\t});\r\n\t$(\"#getHallticketId\").click(function(e){\r\n\t    setTimeout('Decrement1()',1000);\r\n\t    document.location.href = \"StudentLoginNewAction.do?method=studentLoginGetHallTicket\";\r\n\t});\r\n\t\r\n});\r\n\r\n\r\nvar min = 0;\r\nvar sec = 59;\r\nvar minute;\r\nvar second;\r\n\r\nfunction Decrement1() {\r\n\tif (second < 59) {\r\n\t\tsecond = sec;\r\n\t}else{\r\n\t\tminute = getminute();\r\n\t\tsecond = getsecond();\r\n\t}\r\n\tif(minute == 0 && second <= 1){\r\n\t\twindow.stop();\r\n\t\t$.confirm({\r\n\t\t\t'message'    : ' The server is busy at the moment. Please try again later',\r\n\t\t\t'draggable'   : true,\r\n\t\t\t'buttons'    : {\r\n\t\t\t\t'Ok'    : {\r\n\t\t\t\t\t'class'    : 'blue',\r\n\t\t\t\t\t'action': function(){\r\n\t\t\t\t\t\tdocument.location.href=\"StudentLoginNewAction.do?method=returnToHomePage\";\r\n\t\t\t\t\t\t$.confirm.hide();\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t});\r\n\t}else{\r\n\t\tsec--;\r\n\t\tsetTimeout('Decrement1()',1000);\r\n\t}\r\n}\r\nfunction getminute() {\r\n\t//minutes is seconds divided by 60, rounded down\r\n\tmin = Math.floor(sec / 60);\r\n\treturn min;\r\n}\r\nfunction getsecond() {\r\n\t//take mins remaining (as seconds) away from total seconds remaining\r\n\treturn sec-Math.round(min *60);\r\n}\r\n\r\nfunction getFeePaymentForPhDStudent(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"OnlineFeePymtForPhDStudent.do?method=initOnlineFeePymtForPhDStudent&proceedWithPayment=false\";\r\n\t}\r\n}\r\n//added by ram \r\nfunction getFeePaymentInstallmentsPhDStudent(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"OnlineFeePymtForPhDStudent.do?method=initOnlineFeePymtInstallmentsPhDStudent\";\r\n\t}\r\n}\r\n//end\r\nfunction marksCardAttestation(studentId){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"attestMarksCard.do?method=initAttestMarksCard&studentId=\"+studentId+\"&isOriginalTranscript=false\";\r\n\t}\r\n}\r\nfunction originalTranscriptRequest(studentId){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"attestMarksCard.do?method=initOriginalTransScriptRequest&studentId=\"+studentId+\"&isOriginalTranscript=true\";\r\n\t}\r\n}\r\nfunction certificateRequest(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"certificateRequest1.do?method=initCertificateRequest\";\r\n\t}\r\n}\r\nfunction hostelApplicationStatus(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"hostelOnlineApplication.do?method=initHostelOnlineStatus\";\r\n\t}\r\n}\r\nfunction hostelApplication(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"hostelOnlineApplication.do?method=initHostelOnlineApp\";\r\n\t}\r\n}\r\nfunction midSemesterRepeatExamFeesPayment(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"MidSemRepeatExamApplication.do?method=initRepeatExamFeePayment\";\r\n\t}\r\n}\r\nfunction supplementaryImprovementApplication(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"newSupplementaryImpApp1.do?method=checkSupplementaryImpApplicationForStudentLogin\";\r\n\t}\r\n}\r\nfunction convocationRegistration(){\r\n\tclickCount++;\r\n\tif(clickCount==1){\r\n\t\tdocument.location.href = \"onlineExamSuppApplication.do?method=initConvocationRegistration\";\r\n\t}\r\n}\r\n"
          },
