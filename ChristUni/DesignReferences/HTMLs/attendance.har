            "text": ".login_leftlinks {\r\n\tfont-family: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 11px;\r\n\tcolor: #003399;\r\n\ttext-decoration: none;\r\n\tfont-weight: bold;\r\n}\r\n\r\n/* .heading {\r\n\tfont-family: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 11px;\r\n\tcolor: #003399;\r\n\ttext-decoration: none;\r\n    font-weight: bold;\r\n} */\r\n\r\n.heading {\r\n\tfont-family:Verdana,Arial,Helvetica,sans-serif;\r\n\tfont-size:11px;\r\n\tcolor:#34485C;\r\n\ttext-decoration:none;\r\n\tfont-weight:bold;\r\n\tpadding-left: 10px;\r\n\tbackground: #F7F7F7\r\n}\r\n\r\n.Bredcrumbs {\r\n\tfont-family: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 11px;\r\n\tcolor: #34485C;\r\n\ttext-decoration: none;\r\n\tfont-weight: bold;\r\n\t/* padding-left: 9px; */\r\n}\r\n/* .heading_white {\r\n\tfont-family: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 11px;\r\n\tcolor: #FFFFFF;\r\n\ttext-decoration: none;\r\n    font-weight: bold;\r\n    padding-left: 8px;\r\n} */\r\n.heading_white {\r\n\tfont-family:Verdana,Arial,Helvetica,sans-serif;\r\n\tfont-size:11px;\r\n\tcolor:#34485C;\r\n\ttext-decoration:none;\r\n\tbackground:url(../images/Tcenter.gif);\r\n\tfont-weight: bold;\r\n}\r\n\r\n\r\n.heading_orange {\r\n\tfont-family: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 11px;\r\n\tcolor: #FF6600;\r\n\ttext-decoration: none;\r\n    font-weight: bold;\r\n}\r\n\r\n\r\n\r\n.heading_tablehead {\r\n\tfont-family: \"calibri\", Garamond, 'Comic Sans';\r\n\tfont-size: 11px;\r\n\tcolor: #333333;\r\n\ttext-decoration: none;\r\n    font-weight: bold;\r\n    background-color: #C2C2C2;\r\n}\r\n\r\n\r\n\r\n.news {\r\n\tfont-family: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 10px;\r\n\tcolor: #003399;\r\n\ttext-decoration: none;\r\n\tfont-weight: normal;\r\n\tbackground: #F7F7F7;\r\n}\r\n\r\n.newsLink {\r\n\tfont-family: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 9px;\r\n\tcolor: #FF6600;\r\n\ttext-decoration: none;\r\n}\r\n\r\n\r\n\r\n.button {\r\n\tCOLOR: #FFFFFF;\r\n\tFONT-FAMILY: Verdana, Arial, Helvetica, sans-serif;\r\n\tFONT-SIZE: 11px;\r\n\tFONT-WEIGHT: bold;\r\n\tfont-style: normal;\r\n\ttext-decoration: none;\r\n\tpadding-right: 8px;\r\n\tpadding-left: 8px;\r\n\tpadding-top: 4px;\r\n\tpadding-bottom: 4px;\r\n\tbackground-color: #0066CC;\r\n\tborder: 1px solid #333333;\r\n\theight:4px;\r\n\tbackground-repeat: no-repeat;\r\n\r\n   }\r\n.button_type {\r\n\tFONT-FAMILY: Verdana, Arial, Helvetica, sans-serif;\r\n\tfont-size: 11px; \r\n\tfont-weight: bold; \r\n\tbackground:#0066cc none; \r\n\tcolor:#ffffff; width:4em;\r\n}\r\n\r\n/*old .formbutton{\r\ncursor:pointer;\r\nborder:outset 1px #ccc;\r\nbackground:#999;\r\ncolor:#6663366;\r\nfont-weight:bold;\r\npadding: 1px 2px;\r\nfont: Verdana, Arial, Helvetica, sans-serif;\r\nfont-size:10px;\r\nbackground:url(../images/formbg.gif) repeat-x left top;\r\n} */\r\n\r\n/* .formbutton {\r\n\tcursor:pointer;\r\n\tborder:outset 1px #ccc;\r\n\tbackground:#999;\r\n\tcolor:#fff;\r\n\tfont-weight:bold;\r\n\tpadding:1px 2px;\r\n\tfont:Verdana,Arial,Helvetica,sans-serif;\r\n\tfont-size:10px;\r\n\tbackground:url(../images/FormButton.gif);\r\n} */\r\n\r\n.formbutton {\r\n\tfont-size:12px;font-weight: bold;border:outset 1px #2A3F54;cursor:pointer;bold;color:#fff;background-color:#2A3F54;border-color:#2A3F54;-webkit-border-radius:5px; -moz-border-radius:5px; border-radius:5px;height: 25px;padding-bottom: 3px;\r\n}\r\n.formbutton.focus,.formbutton:focus {\r\n\tfont-size:12px;font-weight: bold;border:outset 1px #2A3F54;cursor:pointer;color:#fff;background-color:#446788;border-color:#446788;-webkit-border-radius:5px; -moz-border-radius:5px; border-radius:5px;height: 25px;padding-bottom: 3px;\r\n}\r\n.formbutton:hover {\r\n\tfont-size:12px;font-weight: bold;border:outset 1px #2A3F54;cursor:pointer;color:#fff;background-color:#446788;border-color:#446788;-webkit-border-radius:5px; -moz-border-radius:5px; border-radius:5px;height: 25px;padding-bottom: