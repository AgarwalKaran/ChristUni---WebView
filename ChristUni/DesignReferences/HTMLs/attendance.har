            "text": ".cothight {\r\n\tmin-height: 540px;\r\n}\r\n\r\n.toggleMenu {\r\n\tdisplay: none;\r\n\tpadding: 0px;\r\n\tcolor: #fff;\r\n}\r\n\r\n.nav {\r\n\tlist-style: none; *\r\n\tzoom: 1;\r\n}\r\n\r\n.nav:before,.nav:after {\r\n\tcontent: \" \";\r\n\tdisplay: table;\r\n}\r\n\r\n.nav:after {\r\n\tclear: both;\r\n}\r\n\r\n.nav ul {\r\n\tlist-style: none;\r\n\twidth: 9em;\r\n}\r\n\r\n.nav>li> a {\r\n\tpadding: 0px 30px;\r\n\tcolor: #183883;\r\n\tfont-size: 18px;\r\n\tfont-weight: 450px;\r\n\tfont-family: \"calibri\", Garamond, 'Comic Sans';\r\n\tbackground: url(\"../images/nav-sprite.png\") no-repeat scroll center 30px\r\n\t\trgba(0, 0, 0, 0) !important;\r\n\tmargin: 0px 0px 0px 0px;\r\n \r\n\t\r\n}\r\n\r\n.nav li {\r\n\tposition: relative;\r\n}\r\n\r\n.nav>li {\r\n\ttext-transform: uppercase;\r\n\tfloat: left;\r\n}\r\n\r\n.nav>li>a:hover,.nav>li>a:focus {\r\n\ttext-decoration: none;\r\n\tcolor: #333;\r\n\tbackground-position: center -45px !important;\r\n}\r\n\r\n.nav>li>.parent { /* background-image: url(\"images/downArrow.png\");*/\r\n\tbackground-repeat: no-repeat;\r\n\tbackground-position: right;\r\n\ttop: 0;\r\n}\r\n.nav > li:hover > a {\r\n    color: #f55e15;\r\n    background-image: url(\"../images/nav-sprite.png\") no-repeat scroll center 30px\r\n\t\trgba(0, 0, 0, 0) !important;\r\n\t\tbackground-repeat: repeat;\r\n}\r\nul.NormalMenu ul {\r\n\twidth: 100%;\r\n\tdisplay: none;\r\n\tposition: absolute;\r\n}\r\n\r\nul.NormalMenu li {\r\n\tline-height: 40px;\r\n}\r\n\r\n/****************9-12-14 start************/\r\nul.NormalMenu  li:hover>ul {\r\n\twidth: 100%;\r\n\tdisplay: block;\r\n\tleft: -50%;\r\n\ttop: 100%;\r\n\twidth: 230px;\r\n\tfloat: left;\r\n}\r\n\r\n/****************9-12-14 end************/\r\nul.nav ul {\r\n\tborder-radius: 8px !important;\r\n\tbackground: linear-gradient(to bottom, rgba(255, 255, 255, 0.95) 0%,\r\n\t\trgba(216, 233, 239, 0.95) 100% ) repeat scroll 0 0 rgba(0, 0, 0, 0);\r\n\tbox-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);\r\n}\r\n\r\nul.nav ul li a {\r\n\twidth: 230px !important;\r\n\tpadding-left: 10px !important;\r\n\tborder-bottom: #FFFFFF solid 1px;\r\n\tborder-radius: 8px !important;\r\n\tcolor: #183883;\r\n\tfont-size: 16px !important;\r\n\tfont-weight: 450px;\r\n\tbackground: none;\r\n\tdisplay:inline; \r\n\ttext-decoration: none;\r\n}\r\n\r\nul.NormalMenu  li li:hover>ul {\r\n\twidth: 100%;\r\n\tdisplay: block;\r\n\ttop: 50%;\r\n\tleft: 100%;\r\n}\r\n\r\nul.nav ul {\r\n\twidth: 230px !important;\r\n\tmargin: 0px;\r\n\tpadding: 0px;\r\n\ttop: 100;\r\n}\r\n\r\nul.NormalMenu li:hover>ul li {\r\n\ttop: 100% !important;\r\n\tfloat: left;\r\n}\r\n\r\nul.NormalMenu li:hover>ul li  a {\r\n\ttop: 100% !important;\r\n\twidth: 230px !important;\r\n\tpadding: 0px;\r\n\tmargin: 0px;\r\n\tfloat: left;\r\n\tline-height: 40px;\r\n\ttext-decoration: none;  \r\n}\r\n\r\nul.NormalMenu li:hover>ul li  a:hover {\r\n\tcursor: pointer;\r\n\tbackground: #183883 !important;\r\n\tcolor: #fff;\r\n\twidth: 230px !important;\r\n}\r\n\r\nul.NormalMenu li:hover>ul li ul {\r\n\tcursor: pointer;\r\n\ttop: 25% !important;\r\n}\r\n\r\nul.NormalMenu li:hover>ul li li a {\r\n\tcursor: pointer;\r\n\ttop: 100% !important;\r\n}\r\n\r\nul.NormalMenu li:hover>ul li li a:hover {\r\n\tcursor: pointer;\r\n\tcolor: #fff;\r\n}\r\n\r\n.leftm {\r\n\tdisplay: block;\r\n\ttop: 50%;\r\n\tleft: -100% !important;\r\n}\r\n\r\n@media screen and (max-width: 1024px) {\r\n\t.cothight {\r\n\t\tmin-height: 400px;\r\n\t}\r\n\t.nav>li> a {\r\n\t\tbackground: url(\"../images/nav-sprite.png\") no-repeat scroll center 30px\r\n\t\t\trgba(0, 0, 0, 0) !important;\r\n\t\tcolor: #183883;\r\n\t\tfont-family: \"Source Sans Pro\", sans-serif;\r\n\t\tfont-size: 16px;\r\n\t\tmargin: 0;\r\n\t\tpadding: 0 13px;\r\n\t}\r\n}\r\n\r\n@media screen and (max-width: 800px) {\r\n\t.active {\r\n\t\tdisplay: block;\r\n\t}\r\n\t.nav>li {\r\n\t\tfloat: none;\r\n\t}\r\n\t.nav>li>.parent {\r\n\t\tbackground-position: 95% 50%;\r\n\t}\r\n\t.nav li li .parent { /*background-image: url(\"images/downArrow.png\");*/\r\n\t\tbackground-repeat: no-repeat;\r\n\t\tbackground-position: 95% 50%;\r\n\t}\r\n\tul.nav ul {\r\n\t\tmargin-left: 5%;\r\n\t\twidth: 95%;\r\n\t}\r\n\tul.nav ul {\r\n\t\tborder-radius: 0px !important;\r\n\t\tbox-shadow: none;\r\n\t\twidth: 100%;\r\n\t}\r\n\tul.nav ul li {\r\n\t\tborder-radius: 0px !important;\r\n\t\tbox-shadow: none;\r\n\t\tborder: none;\r\n\t}\r\n\tul.nav ul li a {\r\n\t\tcolor: #fff;\r\n\t\tborder-radius: 0px !important;\r\n\t\tbox-shadow: none;\r\n\t\tborder: none;\r\n\t\twidth: 100%;\r\n\t}\r\n\tul.nav li {\r\n\t\tline-height: 30px;\r\n\t\tbackground: #183883;\r\n\t\tborder-bottom: #FFFFFF solid 1px;\r\n\t}\r\n\t.nav>li a {\r\n\t\tcolor: #fff;\r\n\t}\r\n\t.nav>li a:hover {\r\n\t\tcolor: #fff;\r\n\t}\r\n\t.nav>li>a:hover,.nav>li>a:focus {\r\n\t\ttext-decoration: none;\r\n\t\tcolor: #e1c993;\r\n\t\tbackground-position: center -45px !important;\r\n\t}\r\n}"
