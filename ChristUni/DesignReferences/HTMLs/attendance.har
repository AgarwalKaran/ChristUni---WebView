            "text": "\r\n\r\n\r\n\r\n<!DOCTYPE html PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\r\n<head>\r\n<script src=\"js/layout/studentLayoutNew.js\" type=\"text/javascript\"></script>\r\n</head>\r\n<html>\r\n\r\n<head>\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n\r\n<title>Knowledge Pro</title>\r\n<link rel=\"stylesheet\" href=\"js/newDesignPlugin/css/bootstrap.min.css\" type=\"text/css\" />\r\n<link rel=\"stylesheet\" href=\"js/newDesignPlugin/css/base.css\" type=\"text/css\" />\r\n<link rel=\"stylesheet\" href=\"js/newDesignPlugin/css/menustyle1.css\" type=\"text/css\" />\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"css/styles.css\"/>\r\n\r\n<script type=\"text/javascript\" src=\"js/newDesignPlugin/js/jquery-1.10.1.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/newDesignPlugin/js/bootstrap.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/newDesignPlugin/js/script.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/ajax/Ajax.js\"></script>\r\n<script type=\"text/javascript\" src=\"js/ajax/AjaxUtil.js\"></script>\r\n<style type=\"text/css\">\r\n.cotbox {\r\n\twidth: 100%;\r\n\tfloat: left;\r\n\t margin-top: 130px; \r\n\t  overflow: auto;\r\n}\r\n</style>\r\n</head>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<!DOCTYPE html PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\r\n<html>\r\n<head>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"jquery.confirm/jquery.confirm/jquery.confirm.css\" />\r\n<script type=\"text/javascript\" src=\"jquery.confirm/jquery.confirm/jquery.confirm.js\"></script>\r\n<style type=\"text/css\">\r\n  .home {\r\n  cursor:pointer;\r\n  color: #183883; \r\n  font-size: 18px; \r\n  margin: 0; \r\n  padding: 0 30px;\r\n  }\r\n  .home:hover {\r\n  cursor:pointer;\r\n  font-size: 18px; \r\n  margin: 0; \r\n  padding: 0 30px;\r\n  color: #f55e15;\r\n  }\r\n  .header {\r\n\tback